{
  "id": null,
  "uid": "service-health",
  "title": "Service Health",
  "description": "Service health monitoring from blackbox_exporter probes and log data from Loki",
  "tags": ["monitoring", "services", "health"],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
  },
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "links": [],
  "annotations": {
    "list": []
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Service Status",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "title": "Service Uptime",
      "type": "stat",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "noValue": "NO DATA"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "probe_success{job=\"blackbox\",instance=\"http://localhost:11434/api/tags\"}",
          "refId": "A",
          "legendFormat": "Ollama"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "probe_success{job=\"blackbox\",instance=\"http://localhost:8080/health\"}",
          "refId": "B",
          "legendFormat": "Open-WebUI"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "probe_success{job=\"blackbox\",instance=\"http://localhost:32400/web\"}",
          "refId": "C",
          "legendFormat": "Plex"
        }
      ]
    },
    {
      "id": 3,
      "title": "Service Metrics",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 4,
      "title": "Probe Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "probe_duration_seconds{job=\"blackbox\",instance=\"http://localhost:11434/api/tags\"}",
          "refId": "A",
          "legendFormat": "Ollama"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "probe_duration_seconds{job=\"blackbox\",instance=\"http://localhost:8080/health\"}",
          "refId": "B",
          "legendFormat": "Open-WebUI"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "probe_duration_seconds{job=\"blackbox\",instance=\"http://localhost:32400/web\"}",
          "refId": "C",
          "legendFormat": "Plex"
        }
      ]
    },
    {
      "id": 5,
      "title": "HTTP Status Codes",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "200": {
                  "text": "200 OK",
                  "color": "green"
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 201,
                "to": 299,
                "result": {
                  "color": "green"
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 300,
                "to": 399,
                "result": {
                  "color": "yellow"
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 400,
                "to": 599,
                "result": {
                  "color": "red"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "green", "value": 200 }
            ]
          },
          "noValue": "NO DATA"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "probe_http_status_code{job=\"blackbox\",instance=\"http://localhost:11434/api/tags\"}",
          "refId": "A",
          "legendFormat": "Ollama"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "probe_http_status_code{job=\"blackbox\",instance=\"http://localhost:8080/health\"}",
          "refId": "B",
          "legendFormat": "Open-WebUI"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "probe_http_status_code{job=\"blackbox\",instance=\"http://localhost:32400/web\"}",
          "refId": "C",
          "legendFormat": "Plex"
        }
      ]
    },
    {
      "id": 6,
      "title": "Logs",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 7,
      "title": "Service Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 17 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "{host=\"studio\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Error Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 27 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "{host=\"studio\"} |~ \"(?i)(error|fatal|panic|exception)\"",
          "refId": "A"
        }
      ]
    }
  ]
}
